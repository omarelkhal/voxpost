# Copy to .env only if you need overrides. See docs/SETUP.md.

# Usually set automatically by `voxpost setup-gcp` → ~/.config/voxpost/gcp.json
# VOXPOST_GCP_PROJECT=your-project-id
# VOXPOST_PUBSUB_TOPIC=voxpost-gmail
# VOXPOST_PUBSUB_SUBSCRIPTION=voxpost-gmail-pull

# OAuth Desktop client JSON (required once — from Cloud Console)
# Default path: ~/.config/voxpost/client_secret.json
# VOXPOST_OAUTH_CLIENT_SECRETS=/path/to/client_secret.json

# Optional: service account key for Pub/Sub. If unset, uses Application Default Credentials:
#   gcloud auth application-default login
# VOXPOST_PUBSUB_CREDENTIALS=/path/to/voxpost-pubsub-key.json

# VOXPOST_FETCH_DELAY_SECONDS=2
# VOXPOST_CONFIG_DIR=~/.config/voxpost
